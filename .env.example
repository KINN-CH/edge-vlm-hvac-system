# ─────────────────────────────────────────
# .env 파일 설정 가이드
# ─────────────────────────────────────────
# 
# 이 파일을 복사하여 .env 파일을 만들고
# 아래 값들을 자신의 API 키로 채우세요.
# 
# .env 파일은 .gitignore에 등록되어 있어
# GitHub에 업로드되지 않습니다.
#

# 날씨 API 키 (현재는 기본값 사용)
WEATHER_API_KEY=97e9ad342e69a006e6c55886b18842c2

# 공기질 API 키
# - 공공데이터포털(data.go.kr)에서 발급받은 키를 입력하세요
AIR_QUALITY_API_KEY=YOUR_API_KEY_HERE

# 공기질 측정소 이름 (기본값: 장림동)
AIR_QUALITY_STATION=장림동
